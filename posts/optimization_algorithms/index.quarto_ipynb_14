        "        layer.weights += -self.current_learning_rate * layer.dloss_dweights\n",
        "        layer.biases += -self.current_learning_rate * layer.dloss_dbiases\n",
        "\n",
        "    def post_update_params(self):\n",
        "        self.iterations += 1"
